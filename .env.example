# Anthropic — server-side only, never expose to browser
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DocuSign — server-side only, never expose to browser
DOCUSIGN_CLIENT_ID=your_integration_key_here
DOCUSIGN_CLIENT_SECRET=your_secret_key_here
DOCUSIGN_ACCOUNT_ID=your_account_id_here
DOCUSIGN_BASE_URL=https://na4.docusign.net/restapi
DOCUSIGN_REDIRECT_URI=http://localhost:5173/auth/docusign/callback

# SHAED Signatories — server-side only
SHAED_SIGNER_EMAIL_PRIMARY=ryan@shaed.ai
SHAED_SIGNER_NAME_PRIMARY=Ryan Pritchard
SHAED_SIGNER_EMAIL_SECONDARY=eddie@shaed.ai
SHAED_SIGNER_NAME_SECONDARY=Eddie Schick

# Frontend — safe to expose (not a secret)
VITE_API_BASE_URL=http://localhost:5173

# DocuSign Sandbox Mode (set to "true" for sandbox)
VITE_DOCUSIGN_SANDBOX=true
